# Google Gemini API key — get from https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Groq API key (free-tier fallback LLM) — get from https://console.groq.com/
# 14,400 req/day free. Optional if GOOGLE_API_KEY is set.
GROQ_API_KEY=your_groq_api_key_here

# Stripe secret key — get from https://dashboard.stripe.com/
# Use sk_test_... for sandbox, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
